# ============================================================
# REPO-RAG — .gitignore
# ============================================================

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
.Python

# Virtual environments
venv/
.venv/
env/
ENV/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/

# Test & coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# ── Environment & secrets ────────────────────────────────────
# Ignore all .env files ...
.env
.env.local
.env.*.local

# ... EXCEPT .env.example (safe template for other devs)
!.env.example

*.pem
*.key
*.cert
*.p12

# ── Project-specific data ────────────────────────────────────
# Cloned repositories (can be re-cloned)
backend/cloned_repos/

# ChromaDB persistent storage (can be re-indexed)
backend/chroma_db/

# HuggingFace model cache (large, re-downloaded automatically)
backend/.cache/
.cache/
*.bin
*.safetensors

# ── Node / Frontend ──────────────────────────────────────────
node_modules/
frontend/node_modules/

# Vite build output
frontend/dist/
frontend/dist-ssr/
frontend/.vite/

# ── IDEs & editors ───────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── OS ───────────────────────────────────────────────────────
.DS_Store
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini
Thumbs.db

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Jupyter (if ever used for testing) ───────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Misc ─────────────────────────────────────────────────────
*.bak
*.tmp
*.temp
.cache/